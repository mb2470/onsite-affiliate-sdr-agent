# Agentic Control Plane (Netlify)
# Set these in Netlify dashboard (or locally in .env). Never commit real values.

# Required for ACP adapters
# VITE_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: Governance Hub (Repo B)
# ACP_BASE_URL=
# ACP_KERNEL_KEY=

# Echelon installer may set KERNEL_ID and INTEGRATION; override in production if needed.
