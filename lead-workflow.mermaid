flowchart TD
  %% =========================================
  %% AI SDR AGENT — CURRENT PIPELINE
  %% =========================================

  %% Intake
  A1[Single website add]
  A2[Bulk website add]
  A3[CSV import]
  A4[StoreLeads discovery]

  A1 --> L0[(leads.status = new)]
  A2 --> L0
  A3 --> L0
  A4 --> L1[(leads.status = enriched)]

  %% Enrichment waterfall
  L0 --> E1{StoreLeads lookup}
  E1 -->|hit| E1D[Store data + ICP score]
  E1 -->|miss| E2{Apollo org enrichment}
  E2 -->|hit| E2D[Company firmographics + ICP score]
  E2 -->|miss| E3{Claude web research}
  E3 -->|hit| E3D[Research notes + ICP fit]
  E3 -->|miss| EN[Remain new / pending]

  E1D --> FIT{ICP fit}
  E2D --> FIT
  E3D --> FIT

  FIT -->|HIGH| H[(leads.icp_fit = HIGH)]
  FIT -->|MEDIUM| M[(leads.icp_fit = MEDIUM)]
  FIT -->|LOW| LO[(leads.icp_fit = LOW)]

  H --> LE[(leads.status = enriched)]
  M --> LE
  LO --> LE

  %% Contact discovery
  LE --> C0{Need contacts?}
  C0 -->|yes| C1{contact_database match by domain}
  C1 -->|found| C1D[Rank contacts by title relevance]
  C1 -->|none| C2{Apollo contact discovery}

  C2 -->|verified| C2V[Insert contact + apollo_email_status=verified]
  C2 -->|risky: extrapolated/catch_all/unavailable| C2R[Insert contact + requires ELV]
  C2 -->|invalid| C2X[Discard invalid]

  C2V --> C1D
  C2R --> C1D

  %% Verification + send
  C1D --> S0{Send workflow}
  S0 --> V1{Cached Apollo status}
  V1 -->|verified| SEND[Send via Gmail API]
  V1 -->|risky or missing| V2{EmailListVerify}
  V2 -->|safe| SEND
  V2 -->|bad| BLK[Block + remove bad contact]

  SEND --> O1[(outreach_log insert)]
  O1 --> O2[(leads.status = contacted)]
  O1 --> O3[(activity_log: email_sent)]

  %% Post-send lifecycle
  O2 --> R0{Reply check}
  O2 --> B0{Bounce check}

  R0 -->|real reply| R1[(leads.status = replied)]
  R0 -->|no reply| F0{Follow-up engine}
  F0 -->|+3 days| F1[Follow-up #1]
  F1 -->|+5 days no reply| F2[Follow-up #2]
  F2 -->|still no reply| F3[Sequence complete]

  B0 -->|bounced| B1[Suppress address + reset lead for retry]
  B0 -->|delivered| R0

  %% Automation lane
  AG[Autonomous agent / scheduled batch jobs]
  AG --> LE
  AG --> S0
  AG --> R0
  AG --> B0

  %% Data plane
  subgraph Supabase
    D1[(organizations / user_organizations)]
    D2[(leads)]
    D3[(contact_database)]
    D4[(contacts)]
    D5[(outreach_log / emails)]
    D6[(activity_log / agent_jobs / agent_settings)]
  end

  L0 -.org scoped.-> D2
  LE -.org scoped.-> D2
  C1D -.read/write.-> D3
  C1D -.session contacts.-> D4
  O1 -.write.-> D5
  SEND -.audit trail.-> D6

  %% Styling
  style H fill:#166534,color:#fff
  style M fill:#854d0e,color:#fff
  style LO fill:#991b1b,color:#fff
  style SEND fill:#6d28d9,color:#fff
  style BLK fill:#991b1b,color:#fff
  style R1 fill:#166534,color:#fff
  style B1 fill:#991b1b,color:#fff
  style AG fill:#1e40af,color:#fff
